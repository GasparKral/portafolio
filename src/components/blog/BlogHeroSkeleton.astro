---
// Hero skeleton: shown when there are no blog entries yet
---

<section class="relative w-full min-h-[55vh] flex flex-col justify-end overflow-hidden px-8 py-12 md:px-16 md:py-16 rounded-2xl">
  <!-- Background shimmer -->
  <div class="absolute inset-0 bg-muted animate-pulse rounded-2xl" />

  <!-- Decorative accent bar -->
  <div class="absolute top-0 left-0 w-1 h-full bg-accent/30 rounded-l-2xl" />

  <div class="relative z-10 flex flex-col gap-4 max-w-2xl">
    <!-- Badge skeleton -->
    <div class="h-5 w-28 rounded-full bg-border animate-pulse" />

    <!-- Title skeleton -->
    <div class="flex flex-col gap-2">
      <div class="h-9 w-3/4 rounded-lg bg-border animate-pulse" />
      <div class="h-9 w-1/2 rounded-lg bg-border animate-pulse" style="animation-delay: 80ms" />
    </div>

    <!-- Description skeleton -->
    <div class="flex flex-col gap-2 mt-2">
      <div class="h-4 w-full rounded bg-border animate-pulse" style="animation-delay: 120ms" />
      <div class="h-4 w-5/6 rounded bg-border animate-pulse" style="animation-delay: 160ms" />
      <div class="h-4 w-2/3 rounded bg-border animate-pulse" style="animation-delay: 200ms" />
    </div>

    <!-- Meta skeleton: date + read time -->
    <div class="flex gap-4 mt-3">
      <div class="h-4 w-24 rounded bg-border animate-pulse" style="animation-delay: 240ms" />
      <div class="h-4 w-20 rounded bg-border animate-pulse" style="animation-delay: 280ms" />
    </div>

    <!-- CTA skeleton -->
    <div class="h-10 w-36 rounded-lg bg-border animate-pulse mt-2" style="animation-delay: 320ms" />
  </div>

  <!-- Empty state label -->
  <div class="absolute top-6 right-6 flex items-center gap-2 opacity-40">
    <div class="w-2 h-2 rounded-full bg-muted-foreground animate-pulse" />
    <span class="text-xs text-muted-foreground font-medium tracking-widest uppercase">
      coming soon
    </span>
  </div>
</section>
