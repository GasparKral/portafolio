---
// Skeleton card used while no entries exist or as loading placeholder
---

<div class="relative flex flex-col gap-3 rounded-xl border border-border bg-card p-5 overflow-hidden">
  <!-- Lang badge skeleton -->
  <div class="h-4 w-8 rounded-full bg-muted animate-pulse" />

  <!-- Title skeleton -->
  <div class="flex flex-col gap-1.5">
    <div class="h-4 w-full rounded bg-border animate-pulse" style="animation-delay: 40ms" />
    <div class="h-4 w-3/4 rounded bg-border animate-pulse" style="animation-delay: 80ms" />
  </div>

  <!-- Description skeleton -->
  <div class="flex flex-col gap-1.5 flex-1">
    <div class="h-3 w-full rounded bg-border animate-pulse" style="animation-delay: 100ms" />
    <div class="h-3 w-5/6 rounded bg-border animate-pulse" style="animation-delay: 130ms" />
    <div class="h-3 w-2/3 rounded bg-border animate-pulse" style="animation-delay: 160ms" />
  </div>

  <!-- Footer skeleton -->
  <div class="flex items-center justify-between pt-3 border-t border-border mt-auto">
    <div class="h-3 w-20 rounded bg-border animate-pulse" style="animation-delay: 200ms" />
    <div class="h-4 w-4 rounded bg-border animate-pulse" style="animation-delay: 220ms" />
  </div>
</div>
